generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  name            String
  ownerId         String   @map("owner_id") @db.Uuid
  ownerName       String   @map("owner_name")
  status          String   @default("DRAFT")
  memberCount     Int      @default(1) @map("member_count")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  budget       Budget?
  expenseNotes ExpenseNote[]

  @@index([organizationId], name: "idx_projects_organization_id")
  @@map("projects")
}

model Budget {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId       String   @unique @map("project_id") @db.Uuid
  totalAmount     Decimal  @map("total_amount") @db.Decimal(12, 2)
  allocatedAmount Decimal  @map("allocated_amount") @db.Decimal(12, 2)
  committedAmount Decimal  @default(0) @map("committed_amount") @db.Decimal(12, 2)
  currency        String   @default("THB")
  alerts          Json     @default("[]")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId], name: "idx_budgets_project_id")
  @@map("budgets")
}

model ExpenseNote {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId       String   @map("project_id") @db.Uuid
  requesterId     String?  @map("requester_id") @db.Uuid
  requesterName   String   @map("requester_name")
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("THB")
  category        String
  description     String
  vendorName      String?  @map("vendor_name")
  status          String   @default("DRAFT")
  priceSignal     String   @default("PASS") @map("price_signal")
  policySignal    String   @default("PASS") @map("policy_signal")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approvalSteps ApprovalStep[]

  @@index([projectId], name: "idx_expense_notes_project_id")
  @@index([status], name: "idx_expense_notes_status")
  @@map("expense_notes")
}

model ApprovalStep {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expenseNoteId String    @map("expense_note_id") @db.Uuid
  approverId    String?   @map("approver_id") @db.Uuid
  approverName  String    @map("approver_name")
  level         Int
  status        String    @default("PENDING")
  comment       String?
  decidedAt     DateTime? @map("decided_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  expenseNote ExpenseNote @relation(fields: [expenseNoteId], references: [id], onDelete: Cascade)

  @@index([expenseNoteId], name: "idx_approval_steps_expense_note_id")
  @@index([status], name: "idx_approval_steps_status")
  @@map("approval_steps")
}
